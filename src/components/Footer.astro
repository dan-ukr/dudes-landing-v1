---
import Modal from './Modal.astro';
---
<footer class="site-footer">
  <div class="legal-links">
    <button onclick="document.getElementById('privacy-modal').showModal()">Privacy Policy</button>
    <button onclick="document.getElementById('terms-modal').showModal()">Terms & Conditions</button>
  </div>

  <Modal id="privacy-modal" title="Privacy Policy">
    <p>Updated at 2026-04-15</p>
    <p>WeatherDude (“we,” “our,” or “us”) is committed to protecting your privacy...</p>
    </Modal>

  <Modal id="terms-modal" title="Terms & Conditions">
    <p>Updated at 2026-04-15</p>
    <p>By accessing and placing an order with WeatherDude...</p>
    </Modal>
</footer>

<style>
  .site-footer {
    padding: 2rem;
    margin-top: 4rem;
    border-top: 5px solid black;
    background-color: var(--wd-yellow); /* Виділяємо футер кольором */
    text-align: center;
  }
  
  .legal-links button {
    background: white;
    border: 3px solid black;
    padding: 10px 20px;
    margin: 10px;
    font-family: 'ActayWide', sans-serif;
    font-weight: 900;
    text-transform: uppercase;
    border-radius: 99px;
    box-shadow: 4px 4px 0px black;
    cursor: pointer;
    transition: all 0.2s;
  }
  
  .legal-links button:hover {
    background: var(--wd-pink);
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0px black;
  }
</style>