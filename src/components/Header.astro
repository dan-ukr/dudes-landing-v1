---
import LanguagePicker from './LanguagePicker.astro';
import { ui } from '../i18n/ui';

interface Props {
  lang: string;
}
const { lang } = Astro.props;
const t = ui[lang as keyof typeof ui];
---

<header class="dudes-header">
  <a href="#top" class="brand-word" aria-label="DUDES — back to top">DUDES</a>

  <nav class="anchor-nav">
    <a href="#products">{t['nav.products']}</a>
    <a href="#team">{t['nav.team']}</a>
    <a href="#contact">{t['nav.contact']}</a>
  </nav>

  <div class="lang-dropdown">
    <div class="lang-trigger">🌐 {lang.toUpperCase()} ▼</div>
    <div class="lang-list">
      <LanguagePicker currentLang={lang} />
    </div>
  </div>
</header>

<style>
  .dudes-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 900;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    padding: 10px 24px;
    background: rgba(255, 234, 244, 0.85);
    backdrop-filter: blur(8px);
    border-bottom: 4px solid black;
  }

  .brand-word {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.15rem;
    letter-spacing: 0.02em;
    text-decoration: none;
    color: black;
    flex-shrink: 0;
  }

  .anchor-nav {
    display: flex;
    gap: 28px;
  }

  .anchor-nav a {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1rem;
    color: black;
    text-decoration: none;
    border-bottom: 3px solid transparent;
    transition: border-color 0.2s ease;
  }

  .anchor-nav a:hover {
    border-color: var(--wd-lime, #D0FF00);
  }

  .lang-dropdown {
    position: relative;
    flex-shrink: 0;
  }

  .lang-trigger {
    background: white;
    border: 3px solid black;
    padding: 6px 14px;
    font-family: var(--font-display);
    font-weight: 900;
    border-radius: 99px;
    box-shadow: 3px 3px 0px black;
    cursor: pointer;
    font-size: 0.8rem;
    white-space: nowrap;
  }

  .lang-list {
    display: none;
    position: absolute;
    top: 110%;
    right: 0;
    background: white;
    border: 5px solid black;
    border-radius: 25px;
    max-height: 300px;
    width: 260px;
    overflow-y: auto;
    box-shadow: 10px 10px 0px black;
    padding: 16px;
  }

  .lang-dropdown:hover .lang-list {
    display: block;
  }

  @media (max-width: 768px) {
    .dudes-header {
      padding: 8px 14px;
    }
    .anchor-nav {
      display: none;
    }
  }
</style>
