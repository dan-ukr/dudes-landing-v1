---
// The real logo (public/icons/DudesLogo.svg) was optimized with svgo
// (1.7MB -> ~59KB; the original had thousands of tiny traced micro-rectangles)
// and its paths were bucketed by position into pink/lime/blue/yellow quadrant
// groups plus a static center group (background ring outline + "DUDES"
// wordmark) — see src/components/dudes-logo-ring.svg. That split is what
// makes the drag-to-rotate ring and the click-to-reassemble bounce possible.
// Imported with Vite's `?raw` so the markup is inlined at build time —
// a plain fs.readFileSync doesn't survive the server-bundle/prerender step.
import ringSvg from './dudes-logo-ring.svg?raw';

interface Props {
  size?: string; // any CSS length, e.g. "40px" or "clamp(180px, 42vw, 320px)"
  static?: boolean; // renders inert (no drag/click interactions) — for small reuse spots
  class?: string;
}
const { size = 'clamp(200px, 42vw, 340px)', static: isStatic = false, class: className = '' } = Astro.props;
---

<div class:list={['dudes-logo', { 'is-static': isStatic }, className]} style={`--dudes-logo-size: ${size}`} data-dudes-logo>
  <Fragment set:html={ringSvg} />
</div>

<style>
  .dudes-logo {
    display: block;
    width: var(--dudes-logo-size);
    height: var(--dudes-logo-size);
    -webkit-tap-highlight-color: transparent;
  }
  .dudes-logo :global(svg) {
    display: block;
    width: 100%;
    height: 100%;
    overflow: visible;
  }

  .dudes-logo :global(.dudes-ring) {
    transform-box: view-box;
    transform-origin: 603px 603px;
    transform: rotate(var(--ring-rotation, 0deg));
    cursor: grab;
  }
  .dudes-logo.grabbing :global(.dudes-ring) { cursor: grabbing; }

  .dudes-logo :global(.q-pink),
  .dudes-logo :global(.q-lime),
  .dudes-logo :global(.q-blue),
  .dudes-logo :global(.q-yellow) {
    transform-box: view-box;
    transform-origin: 603px 603px;
  }

  .dudes-logo :global(.click-hit-area) {
    cursor: pointer;
  }

  @media (prefers-reduced-motion: no-preference) {
    .dudes-logo:not(.is-static) {
      animation: dudes-enter 0.7s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    }
  }
  @keyframes dudes-enter {
    0%   { transform: scale(0.7); opacity: 0; }
    100% { transform: scale(1); opacity: 1; }
  }

  /* Click-to-reassemble: each quadrant flies out to its own corner and
     snaps back. Re-triggerable — see the script below, which toggles
     this class off and on so the animation can replay every click. */
  .dudes-logo :global(.dudes-ring.bounce .q-pink)   { animation: dudes-bounce-pink 1.1s cubic-bezier(.34,1.56,.64,1); }
  .dudes-logo :global(.dudes-ring.bounce .q-lime)   { animation: dudes-bounce-lime 1.1s cubic-bezier(.34,1.56,.64,1); }
  .dudes-logo :global(.dudes-ring.bounce .q-blue)   { animation: dudes-bounce-blue 1.1s cubic-bezier(.34,1.56,.64,1); }
  .dudes-logo :global(.dudes-ring.bounce .q-yellow) { animation: dudes-bounce-yellow 1.1s cubic-bezier(.34,1.56,.64,1); }

  @keyframes dudes-bounce-pink {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    35%, 55% { transform: translate(-120px, -120px) rotate(-10deg); }
  }
  @keyframes dudes-bounce-lime {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    35%, 55% { transform: translate(120px, -120px) rotate(10deg); }
  }
  @keyframes dudes-bounce-blue {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    35%, 55% { transform: translate(120px, 120px) rotate(-10deg); }
  }
  @keyframes dudes-bounce-yellow {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    35%, 55% { transform: translate(-120px, 120px) rotate(10deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .dudes-logo :global(.dudes-ring) { cursor: default; }
  }
</style>

<script is:inline>
  document.querySelectorAll('[data-dudes-logo]').forEach((wrap) => {
    if (wrap.classList.contains('is-static')) return;
    const svgEl = wrap.querySelector('svg');
    const ring = wrap.querySelector('.dudes-ring');
    if (!svgEl || !ring) return;

    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    let rotation = 0;
    let mode = null; // 'rotate' | 'click'
    let startAngle = 0;
    let downPos = null;
    let downTime = 0;

    function center() {
      const r = svgEl.getBoundingClientRect();
      return { cx: r.left + r.width / 2, cy: r.top + r.height / 2, halfW: r.width / 2 };
    }
    function angleAt(x, y) {
      const { cx, cy } = center();
      return Math.atan2(y - cy, x - cx) * 180 / Math.PI;
    }
    function distAt(x, y) {
      const { cx, cy } = center();
      return Math.hypot(x - cx, y - cy);
    }

    function triggerBounce() {
      ring.classList.remove('bounce');
      void ring.offsetWidth;
      ring.classList.add('bounce');
    }
    ring.addEventListener('animationend', () => ring.classList.remove('bounce'));

    if (prefersReduced) {
      // Still allow the click-to-reassemble party trick, just skip the drag-rotate.
      wrap.querySelector('.click-hit-area')?.addEventListener('click', triggerBounce);
      return;
    }

    wrap.addEventListener('pointerdown', (e) => {
      const { halfW } = center();
      const d = distAt(e.clientX, e.clientY);
      const ratio = d / halfW;
      downPos = { x: e.clientX, y: e.clientY };
      downTime = Date.now();
      if (ratio <= 260 / 603) {
        mode = 'click';
      } else if (ratio <= 1.05) {
        mode = 'rotate';
        startAngle = angleAt(e.clientX, e.clientY);
        wrap.classList.add('grabbing');
      } else {
        mode = null;
        return;
      }
      wrap.setPointerCapture(e.pointerId);
    });

    wrap.addEventListener('pointermove', (e) => {
      if (mode !== 'rotate') return;
      const a = angleAt(e.clientX, e.clientY);
      ring.style.setProperty('--ring-rotation', rotation + (a - startAngle) + 'deg');
    });

    function endPointer(e) {
      if (mode === 'rotate') {
        const a = angleAt(e.clientX, e.clientY);
        rotation += a - startAngle;
        wrap.classList.remove('grabbing');
      } else if (mode === 'click' && downPos) {
        const moved = Math.hypot(e.clientX - downPos.x, e.clientY - downPos.y);
        const elapsed = Date.now() - downTime;
        if (moved < 8 && elapsed < 500) triggerBounce();
      }
      mode = null;
      downPos = null;
    }
    wrap.addEventListener('pointerup', endPointer);
    wrap.addEventListener('pointercancel', endPointer);
  });
</script>
