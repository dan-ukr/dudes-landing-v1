---
// Real logo asset lives at /public/icons/DudesLogo.svg (~1.7MB, auto-traced,
// flat — no separable per-quadrant groups), so it's referenced as an <img>
// rather than inlined: one cached network request instead of ~1.7MB of raw
// markup duplicated on every one of the 9 language pages. That also rules out
// a piece-by-piece assembly animation on load (nothing to animate
// independently) — this does a simple scale/fade entrance plus a slow idle
// wobble on the whole mark instead.
interface Props {
  size?: string; // any CSS length, e.g. "40px" or "clamp(180px, 42vw, 320px)"
  static?: boolean; // no entrance/idle animation — used for small reuse spots
  class?: string;
}
const { size = 'clamp(180px, 42vw, 320px)', static: isStatic = false, class: className = '' } = Astro.props;
---

<img
  src="/icons/DudesLogo.svg"
  alt="DUDES"
  class:list={['dudes-logo', { 'is-static': isStatic }, className]}
  style={`--dudes-logo-size: ${size}`}
  width="120"
  height="120"
  loading="eager"
  decoding="async"
/>

<style>
  .dudes-logo {
    display: block;
    width: var(--dudes-logo-size);
    height: var(--dudes-logo-size);
  }

  @media (prefers-reduced-motion: no-preference) {
    .dudes-logo:not(.is-static) {
      animation: dudes-enter 0.7s cubic-bezier(0.34, 1.56, 0.64, 1) both,
                 dudes-idle-wobble 6s ease-in-out 0.9s infinite alternate;
    }
  }

  @keyframes dudes-enter {
    0%   { transform: scale(0.7); opacity: 0; }
    100% { transform: scale(1); opacity: 1; }
  }

  @keyframes dudes-idle-wobble {
    from { transform: rotate(-2deg); }
    to   { transform: rotate(2deg); }
  }
</style>
