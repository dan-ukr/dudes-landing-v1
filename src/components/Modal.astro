---
interface Props {
  id: string;
  title: string;
  fullscreen?: boolean;
  accent?: string;
}
const { id, title, fullscreen = false, accent } = Astro.props;
---

<dialog id={id} class:list={['modal-dialog', { 'modal-fullscreen': fullscreen }]} style={accent ? `--modal-accent: ${accent}` : undefined}>
  <div class="modal-content">
    <div class="modal-header">
      <h2>{title}</h2>
      <button class="close-btn" data-close-modal>✕</button>
    </div>
    <div class="modal-body text-content">
      <slot />
    </div>
  </div>
</dialog>

<style>
  .modal-dialog {
    border: 5px solid black;
    border-radius: 25px;
    box-shadow: 10px 10px 0px black;
    padding: 0;
    max-width: 800px;
    width: 90%;
    background-color: var(--wd-white);
    color: black;
  }

  .modal-dialog::backdrop {
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(5px);
  }

  /* Full-screen variant, used for the product detail overlays — leaves the
     default centered-card look (privacy/terms) completely untouched. */
  .modal-dialog.modal-fullscreen {
    max-width: 100vw;
    width: 100vw;
    height: 100vh;
    max-height: 100vh;
    border-width: 0;
    border-radius: 0;
    box-shadow: none;
    background-color: var(--modal-accent, var(--wd-white));
    margin: 0;
  }

  .modal-dialog.modal-fullscreen .modal-content {
    height: 100%;
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
  }

  .modal-dialog.modal-fullscreen .modal-body {
    max-height: none;
    flex: 1;
  }

  .modal-content { padding: 2rem; }
  
  .modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 5px solid black;
    padding-bottom: 1rem;
    margin-bottom: 1rem;
  }
  
  .modal-header h2 { 
    margin: 0; 
    text-transform: uppercase; 
    font-weight: 900; 
  }
  
  .close-btn { 
    cursor: pointer; 
    background: var(--wd-pink); 
    border: 3px solid black; 
    border-radius: 50%;
    width: 45px;
    height: 45px;
    font-size: 1.5rem;
    font-weight: bold;
    box-shadow: 4px 4px 0px black;
    transition: all 0.2s ease;
  }
  
  .close-btn:hover { 
    background: var(--wd-lime); 
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0px black;
  }
  
  .modal-body { 
    max-height: 60vh; 
    overflow-y: auto; 
    padding-right: 10px;
    /* Трохи простіший шрифт для великих текстів, якщо ActayWide важко читати */
    font-family: sans-serif; 
    line-height: 1.6;
  }

  /* Стилізація скролбару під бруталізм */
  .modal-body::-webkit-scrollbar { width: 12px; }
  .modal-body::-webkit-scrollbar-track { background: var(--wd-white); border-left: 3px solid black; }
  .modal-body::-webkit-scrollbar-thumb { background: var(--wd-yellow); border: 3px solid black; border-radius: 6px; }
</style>

<script>
  document.querySelectorAll('dialog').forEach((dialog) => {
    dialog.querySelector('[data-close-modal]')?.addEventListener('click', () => {
      dialog.close();
    });
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close();
    });
  });
</script>