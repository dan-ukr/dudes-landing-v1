---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
const { lang, title = "DUDES" } = Astro.props;
---
<!doctype html>
<html lang={lang}>
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Darker+Grotesque:wght@700;800;900&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style is:global>
        :root {
            /* the old ActayWide file was never actually shipped in /public/fonts — it
               silently fell back to Arial everywhere. Darker Grotesque (already used
               in the MountainDude/CoachDude concept guide) + Inter replace it. */
            --font-display: 'Darker Grotesque', 'Arial Narrow', sans-serif;
            --font-body: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            /* WeatherDude */
            --wd-pink: #FF86CE; --wd-lime: #D0FF00;
            --wd-yellow: #FFE100; --wd-white: #FFEAF4;
            /* MountainDude — from the CoachDude concept guide (dark-mode system) */
            --md-lime: #E3F265; --md-white: #E7E7E7;
            --md-purple: #B5A1FE; --md-gray: #202020;
            /* HungryDude — placeholder palette, no brand assets yet */
            --hd-amber: #FFB454; --hd-cream: #FFF3E1; --hd-brown: #3A2418;
            /* DUDES parent brand */
            --dd-navy: #160A33; --dd-blue: #6C5CE7;
        }
        html, body {
            margin: 0; padding: 0;
            font-family: var(--font-body);
            background-color: var(--wd-white);
            color: black;
            scroll-behavior: smooth;
        }
        h1, h2, h3, h4, button, input, .font-display {
            font-family: var(--font-display);
        }
        html { scroll-padding-top: 70px; }
        @media (max-width: 768px) {
            html { scroll-padding-top: 56px; }
        }
    </style>
    <!-- Google tag (gtag.js) -->
    <script 
            is:inline 
            async 
            src="https://www.googletagmanager.com/gtag/js?id=AW-17988270765"
    ></script>
    <script is:inline>
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('js', new Date());

            gtag('config', 'AW-17988270765');
    </script>
</head>
<body class="antialiased overflow-x-hidden">
    <Header lang={lang} />
    <slot />
    <Footer />
</body>
</html>