---
const { lang } = Astro.params;
---
<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<title>WeatherDude - Personal Style Assistant</title>
		<style is:global>
			:root {
				--wd-black: #1a1a1a; /*  */
				--wd-white: #f0fdfa; /*  */
				--wd-lime: #d4f06d;  /*  */
				--wd-pink: #fbc2eb;  /*  */
				--wd-yellow: #fde68a; /*  */
				--wd-purple: #634390; /*  */
			}
			@font-face {
				font-family: 'ActayWide';
				src: url('/fonts/ActayWide.woff2') format('woff2');
				font-weight: normal; font-style: normal;
			}
			body {
				font-family: 'ActayWide', 'Helvetica', sans-serif;
				background-color: var(--wd-white);
				color: var(--wd-black);
				margin: 0;
			}
			.glowing-card {
				border-radius: 20px;
				padding: 2rem;
				transition: 0.3s;
				box-shadow: 0 0 15px transparent;
			}
			.glowing-card:hover {
				box-shadow: 0 0 25px var(--card-color);
				transform: translateY(-5px);
			}
		</style>
	</head>
	<body>
		<slot />
	</body>
</html>