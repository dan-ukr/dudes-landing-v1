---
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
    title?: string;
    description?: string;
    lang: string;
}

const { title = "WeatherDude", description = "Dress smart.", lang } = Astro.props;
---

<!doctype html>
<html lang={lang}>
    <head>
        <meta charset="UTF-8" /> <meta name="description" content={description} />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>

        <style is:global>
            @font-face {
                font-family: 'ActayWide';
                src: url('/fonts/ActayWide.woff2') format('woff2');
                font-weight: bold;
                font-style: normal;
                font-display: swap;
            }

            :root {
                --wd-pink: #FF86CE;
                --wd-lime: #D0FF00;
                --wd-yellow: #FFE100;
                --wd-white: #FFEAF4;
            }

            html {
                font-family: 'ActayWide', sans-serif; 
                background-color: var(--wd-white);
                color: black;
                scroll-behavior: smooth;
            }

            .glowing-card {
                min-height: 280px;
                border-radius: 45px;
                padding: 2.5rem;
                border: 5px solid black;
                box-shadow: 12px 12px 0px 0px rgba(0,0,0,1);
                transition: 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
                display: flex;
                flex-direction: column;
                justify-content: center;
                text-align: center;
            }

            .glowing-card:hover {
                transform: translate(-4px, -4px);
                box-shadow: 20px 20px 0px 0px rgba(0,0,0,1);
            }

            .wd-bg-element {
                position: absolute;
                width: 120px; height: 120px;
                background-size: contain;
                background-repeat: no-repeat;
                opacity: 0.1;
                transition: 0.6s;
                z-index: 1;
                filter: grayscale(100%);
            }
            .wd-bg-element:hover {
                opacity: 0.8;
                filter: grayscale(0%);
                transform: scale(1.2) rotate(10deg);
            }
        </style>
    </head>
    <body class="antialiased overflow-x-hidden">
        <slot />
    </body>
</html>