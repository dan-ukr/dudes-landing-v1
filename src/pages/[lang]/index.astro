---
export const prerender = true;
import Layout from '../../layouts/layout.astro';
import { ui, languages } from '../../i18n/ui';
import '../../styles/global.css';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = ui[lang as keyof typeof ui];
---

<Layout lang={lang}>
  <main class="w-full relative min-h-screen pt-10 px-4 md:px-10 overflow-hidden">
    
    <nav class="w-full flex justify-end mb-12">
        <div class="relative group">
            <button class="px-6 py-2 rounded-full border-4 border-black bg-white font-black uppercase text-xs flex items-center gap-2">
                🌐 {lang.toUpperCase()} ▼
            </button>
            <div class="hidden group-hover:block absolute right-0 top-full mt-2 bg-white border-4 border-black rounded-2xl p-2 z-[100] max-h-48 overflow-y-auto shadow-[8px_8px_0px_black]">
                {Object.entries(languages).map(([l, label]) => (
                    <a href={`/${l}/`} class="block px-4 py-2 hover:bg-wd-lime rounded-lg font-bold text-[10px] uppercase text-black">
                        {label}
                    </a>
                ))}
            </div>
        </div>
    </nav>

    <div class="max-w-4xl mx-auto text-center mb-16 relative z-10">
      <h1 class="text-5xl md:text-8xl font-black uppercase italic leading-[0.85] tracking-tighter mb-10">
        {t['hero.title']}
      </h1>
      <p class="text-xl md:text-3xl font-bold uppercase tracking-tighter opacity-70">
        {(() => {
          let phrase = t['hero.temp']
            .replace('{temp}', '<span id="temp" class="text-black underline decoration-wd-lime decoration-4">--</span>')
            .replace('{location}', '<span id="loc">...</span>');
          
          phrase = phrase.replace(/(YOU|ТОБІ|TY|TU|DICH|TÚ|TI|ТАБЕ)/g, 
            '<span class="text-black underline decoration-wd-lime decoration-[12px] font-black italic">$1</span>');
          
          return <Fragment set:html={phrase} />;
        })()}
      </p>
    </div>

    <section class="max-w-5xl mx-auto bg-black p-8 md:p-16 rounded-[60px] shadow-[20px_20px_0px_var(--wd-yellow)] border-4 border-black mb-32 transform -rotate-1">
      <form id="waitlist-form" class="flex flex-col md:flex-row gap-6 justify-center items-stretch">
        <input type="email" name="email" placeholder={t['waitlist.placeholder']} class="flex-grow p-6 rounded-full border-4 border-white bg-transparent text-white font-black text-xl md:text-2xl outline-none focus:border-wd-lime placeholder:opacity-30" required />
        <input type="hidden" name="lang" value={lang} />
        <button type="submit" class="bg-wd-lime p-6 px-12 rounded-full font-black text-2xl md:text-3xl uppercase border-4 border-black hover:scale-105 active:scale-95 transition-all shadow-[8px_8px_0px_white]">
          {t['waitlist.btn']}
        </button>
      </form>
      <div id="form-msg" class="mt-8 hidden p-6 rounded-3xl border-4 border-black font-black text-2xl uppercase italic text-center" 
           data-success={t['form.success']} data-error={t['form.error']} data-exists={t['form.exists']}></div>
    </section>

    <div class="max-w-6xl mx-auto flex flex-col gap-24 mb-40 relative z-10">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center">
        <div class="card-brutal bg-wd-lime rotate-2">
          <h3 class="text-3xl md:text-5xl font-black uppercase italic leading-none mb-6">{t['feature.bias.title']}</h3>
          <p class="text-sm md:text-lg font-bold leading-tight">{t['feature.bias.desc']}</p>
        </div>
        <img src="/icons/sun.svg" class="w-32 md:w-48 opacity-20 transform translate-x-10 rotate-12 md:block hidden" />
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center">
        <img src="/icons/shirt.svg" class="w-32 md:w-48 opacity-20 transform -translate-x-10 -rotate-12 md:block hidden order-last md:order-first" />
        <div class="card-brutal bg-wd-pink -rotate-1">
          <h3 class="text-3xl md:text-5xl font-black uppercase italic leading-none mb-6">{t['feature.outfits.title']}</h3>
          <p class="text-sm md:text-lg font-bold leading-tight">{t['feature.outfits.desc']}</p>
        </div>
      </div>

      <div class="max-w-4xl mx-auto w-full card-brutal bg-black border-wd-lime text-wd-lime text-center">
        <h3 class="text-4xl md:text-6xl font-black uppercase mb-4 italic">{t['feature.more.title']}</h3>
        <p class="text-sm md:text-xl font-bold opacity-80 mb-10">{t['feature.more.desc']}</p>
        <img src="/icons/glasses.svg" class="w-32 md:w-40 mx-auto filter invert brightness-200" />
      </div>
    </div>

    <footer class="border-t-8 border-black pt-10 pb-20 px-4 flex flex-col md:flex-row justify-between items-center gap-8 font-black uppercase text-[10px] md:text-xs opacity-60">
        <div>{t['footer.madeby']}</div>
        <img src="/favicon.svg" class="w-12 h-12 grayscale opacity-40 md:order-none order-first" />
        <div>{t['footer.secured']}</div>
    </footer>
  </main>

  <script is:inline>
    async function initWeather() {
      try {
        const geoRes = await fetch('https://ipapi.co/json/');
        const geoData = await geoRes.json();
        document.getElementById('loc').innerText = geoData.city || 'Bolzano';
        const weatherRes = await fetch(`https://api.open-meteo.com/v1/forecast?latitude=${geoData.latitude}&longitude=${geoData.longitude}&current_weather=true`);
        const weatherData = await weatherRes.json();
        document.getElementById('temp').innerText = Math.round(weatherData.current_weather.temperature);
      } catch (e) { document.getElementById('loc').innerText = 'Bolzano'; }
    }
    
    const form = document.getElementById('waitlist-form');
    const msg = document.getElementById('form-msg');
    form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const res = await fetch('/api/subscribe', { method: 'POST', body: new FormData(form) });
        const result = await res.json();
        msg.classList.remove('hidden', 'bg-wd-lime', 'bg-red-500', 'text-black', 'text-white');
        if (res.ok) {
            msg.innerText = msg.dataset.success; msg.classList.add('block', 'bg-wd-lime', 'text-black'); form.reset();
        } else {
            msg.innerText = result.error?.includes('already') ? msg.dataset.exists : msg.dataset.error;
            msg.classList.add('block', 'bg-red-500', 'text-white');
        }
    });
    initWeather();
  </script>
</Layout>

<style>
  .card-brutal { padding: 4rem 2rem; border: 6px solid black; border-radius: 70px; box-shadow: 20px 20px 0px black; width: 100%; display: flex; flex-direction: column; justify-content: center; }
  /* ПРИМУСОВИЙ ШРИФТ ДЛЯ ВСЬОГО */
  * { font-family: 'ActayWide', sans-serif !important; }
  @media (max-width: 768px) {
    .card-brutal { padding: 2.5rem 1.5rem; border-radius: 40px; box-shadow: 10px 10px 0px black; }
  }
</style>