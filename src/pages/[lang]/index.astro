---
export const prerender = true;
import Layout from '../../layouts/layout.astro';
import { ui } from '../../i18n/ui';

export function getStaticPaths() {
  return [
    {params: {lang: 'en'}}, {params: {lang: 'ua'}}, {params: {lang: 'it'}},
    {params: {lang: 'de'}}, {params: {lang: 'es'}}, {params: {lang: 'pt'}},
    {params: {lang: 'fr'}}, {params: {lang: 'be'}}, {params: {lang: 'pl'}}
  ];
}

const { lang } = Astro.params;
const t = ui[lang];
---

<Layout lang={lang}>
  <main class="w-full relative min-h-screen pt-20 px-4 md:px-10">
    
    <div class="max-w-4xl mx-auto flex flex-col items-center gap-10 text-center mb-24 relative z-10">
      <h1 class="text-6xl md:text-[8rem] font-black uppercase italic leading-[0.8] tracking-tighter">
        {t['hero.title']}
      </h1>
      <p class="text-2xl font-bold uppercase tracking-tighter opacity-70">
         It's <span id="temp" class="text-black underline decoration-wd-lime decoration-4">--</span>°C in Bolzano.
      </p>
    </div>

    <section class="max-w-5xl mx-auto bg-black p-10 md:p-16 rounded-[80px] shadow-[25px_25px_0px_var(--wd-yellow)] border-4 border-black mb-32 relative z-10 transform -rotate-1">
      <h2 class="text-white text-5xl font-black uppercase mb-10 italic tracking-tighter text-center">
        {t['waitlist.title']}
      </h2>
      
      <form id="waitlist-form" class="flex flex-col md:flex-row gap-6 justify-center items-stretch">
        <input 
          type="email" 
          name="email"
          placeholder={t['waitlist.placeholder']} 
          class="flex-grow p-8 rounded-full border-4 border-white bg-transparent text-white font-black text-2xl outline-none focus:border-wd-lime placeholder:opacity-30" 
          required 
        />
        <input type="hidden" name="lang" value={lang} />
        
        <button type="submit" class="bg-wd-lime p-8 px-16 rounded-full font-black text-3xl uppercase border-4 border-black hover:scale-105 active:scale-95 transition-all shadow-[8px_8px_0px_white]">
          {t['waitlist.btn']}
        </button>
      </form>
      
      <p id="form-msg" class="mt-8 text-2xl font-black uppercase italic hidden" data-success={t['form.success']} data-error={t['form.error']} data-exists={t['form.exists']}></p>
    </section>

    <div class="max-w-6xl mx-auto flex flex-col gap-32 w-full mb-40 relative z-10">
      
      <div class="flex flex-col md:flex-row items-center justify-between gap-10">
        <div class="glowing-card flex-1 bg-wd-lime rotate-2">
          <h3 class="text-5xl font-black uppercase italic tracking-tighter mb-6">{t['feature.bias.title']}</h3>
          <p class="text-xl font-bold leading-tight">{t['feature.bias.desc']}</p>
        </div>
        <img src="/icons/sun.svg" class="w-64 opacity-20 transform translate-x-10 rotate-12 md:block hidden" />
      </div>

      <div class="flex flex-col md:flex-row-reverse items-center justify-between gap-10">
        <div class="glowing-card flex-1 bg-wd-pink -rotate-2">
          <h3 class="text-5xl font-black uppercase italic tracking-tighter mb-6">{t['feature.outfits.title']}</h3>
          <p class="text-xl font-bold leading-tight">{t['feature.outfits.desc']}</p>
        </div>
        <img src="/icons/shirt.svg" class="w-64 opacity-20 transform -translate-x-10 -rotate-12 md:block hidden" />
      </div>

      <div class="max-w-4xl mx-auto w-full bg-black text-wd-lime border-[6px] border-wd-lime rounded-[100px] p-20 text-center shadow-[30px_30px_0px_black]">
          <h3 class="text-6xl font-black uppercase italic mb-8">{t['feature.more.title']}</h3>
          <p class="text-2xl font-bold opacity-80 max-w-2xl mx-auto mb-10">{t['feature.more.desc']}</p>
          <img src="/icons/glasses.svg" class="w-40 mx-auto filter brightness-0 invert" style="filter: invert(80%) sepia(100%) saturate(1000%) hue-rotate(30deg);" />
      </div>
    </div>

    <footer class="font-black uppercase italic text-8xl md:text-[14rem] pb-40 opacity-5 tracking-tighter leading-none text-center">
      DUDES. INC 2026<br/>BOLZANO ITALY
    </footer>
  </main>

  <script is:inline>
    async function updateWeather() { try { const res = await fetch(`https://api.open-meteo.com/v1/forecast?latitude=46.4983&longitude=11.3548&current_weather=true`); const data = await res.json(); const temp = document.getElementById('temp'); if (temp) temp.innerText = Math.round(data.current_weather.temperature); } catch (e) {} }
    
    const form = document.getElementById('waitlist-form'); 
    const msg = document.getElementById('form-msg');
    
    form?.addEventListener('submit', async (e) => { 
        e.preventDefault(); 
        const res = await fetch('/api/subscribe', { method: 'POST', body: new FormData(form) }); 
        const result = await res.json(); 
        msg.classList.remove('hidden', 'bg-wd-lime', 'bg-red-500'); 
        if (res.ok) { 
            msg.innerText = msg.dataset.success; msg.classList.add('block', 'bg-wd-lime', 'text-black', 'p-6', 'rounded-3xl', 'border-4', 'border-black'); form.reset(); 
        } else { 
            msg.innerText = result.error?.includes('already') ? msg.dataset.exists : msg.dataset.error; msg.classList.add('block', 'bg-red-500', 'text-white', 'p-6', 'rounded-3xl', 'border-4', 'border-black'); 
        } 
        msg.classList.remove('hidden');
    });
    updateWeather();
  </script>
</Layout>