---
export const prerender = true;
import Layout from '../../layouts/layout.astro';
import { ui, languages } from '../../i18n/ui';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = ui[lang as keyof typeof ui];
---

<Layout lang={lang}>
  <div class="top-spacer"></div>

  <main style="max-width: 1200px; margin: 0 auto; padding: 40px 20px; text-align: center;">
    
    <div style="margin-bottom: 80px;">
        <p style="font-size: clamp(1.5rem, 4vw, 2.5rem); font-weight: 700; font-style: italic; text-transform: uppercase; margin-bottom: 20px; opacity: 0.9;">
        {t['hero.subtitle']}
        </p>
      <h1 style="font-size: clamp(3rem, 12vw, 10rem); font-weight: 900; text-transform: uppercase; font-style: italic; line-height: 0.8; margin-bottom: 40px; letter-spacing: -0.05em;">
        {t['hero.title']}
      </h1>
      <p style="font-size: clamp(1.2rem, 4vw, 2rem); font-weight: 900; text-transform: uppercase; opacity: 0.8;">
         {(() => {
           let phrase = t['hero.temp']
            .replace('{temp}', '<span id="temp">--</span>')
            .replace('{location}', '<span id="loc">...</span>');
           
           phrase = phrase.replace(/(YOU|ТОБІ|TY|TU|DICH|TÚ|TI|ТАБЕ)/g, 
             '<span style="text-decoration: underline; text-decoration-color: var(--wd-lime); text-decoration-thickness: 8px; font-weight: 900;">$1</span>');
           return <Fragment set:html={phrase} />;
         })()}
      </p>
    </div>

    <section id="waitlist-form-container" style="background: black; padding: clamp(2rem, 8vw, 80px) 20px; border-radius: clamp(40px, 10vw, 80px); border: 8px solid black; box-shadow: 25px 25px 0px var(--wd-yellow); margin-bottom: 150px; transform: rotate(-1deg);">
      <h2 style="color: white; font-size: clamp(1.5rem, 5vw, 4rem); text-transform: uppercase; font-style: italic; margin-bottom: 50px; line-height: 1;">
        {t['waitlist.title']}
      </h2>
      <form id="waitlist-form" style="display: flex; flex-direction: column; gap: 25px; max-width: 800px; margin: 0 auto;">
        <input 
          type="email" 
          name="email" 
          placeholder={t['waitlist.placeholder']} 
          class="waitlist-input"
          required 
        />
        <input type="hidden" name="lang" value={lang} />
        <button type="submit" class="waitlist-btn">
          {t['waitlist.btn']}
        </button>
      </form>
      <div 
        id="form-msg" 
        style="display: none; margin-top: 40px; font-size: clamp(1.2rem, 3vw, 2rem); font-weight: 900; text-transform: uppercase; font-style: italic; padding: 30px; border-radius: 30px;"
        data-success={t['form.success']}
        data-error={t['form.error']}
        data-exists={t['form.exists']}
      ></div>
    </section>

    <div style="display: flex; flex-direction: column; gap: 120px; text-align: left;">
      <div class="row-brutal">
        <div class="card-brutal" style="background: var(--wd-lime); transform: rotate(2deg);">
          <h3 style="font-size: clamp(2rem, 6vw, 4rem); text-transform: uppercase; font-style: italic; line-height: 0.9; margin: 0;">{t['feature.bias.title']}</h3>
          <p style="font-size: clamp(1rem, 2.5vw, 1.5rem); font-weight: 900; margin-top: 30px; line-height: 1.1;">{t['feature.bias.desc']}</p>
        </div>
        <a href="#temp" class="icon-link"><img src="/icons/sun.svg" style="width: 250px; opacity: 0.3;" /></a>
      </div>

      <div class="row-brutal row-reverse">
        <a href="#waitlist-form-container" class="icon-link"><img src="/icons/shirt.svg" style="width: 250px; opacity: 0.3;" /></a>
        <div class="card-brutal" style="background: var(--wd-pink); transform: rotate(-2deg);">
          <h3 style="font-size: clamp(2rem, 6vw, 4rem); text-transform: uppercase; font-style: italic; line-height: 0.9; margin: 0;">{t['feature.outfits.title']}</h3>
          <p style="font-size: clamp(1rem, 2.5vw, 1.5rem); font-weight: 900; margin-top: 30px; line-height: 1.1;">{t['feature.outfits.desc']}</p>
        </div>
      </div>

      <div class="card-brutal" style="background: black; color: var(--wd-lime); border-color: var(--wd-lime); max-width: 900px; margin: 60px auto; text-align: center; transform: rotate(1deg); width: 100%;">
          <h3 style="font-size: clamp(2rem, 6vw, 5rem); text-transform: uppercase; font-style: italic; line-height: 0.8; margin-bottom: 30px;">{t['feature.more.title']}</h3>
          <p style="font-size: clamp(1rem, 2.5vw, 1.8rem); font-weight: 900; line-height: 1.2;">{t['feature.more.desc']}</p>
          <img src="/icons/glasses.svg" style="width: clamp(100px, 20vw, 180px); margin-top: 50px; filter: invert(81%) sepia(87%) saturate(2976%) hue-rotate(24deg) brightness(108%) contrast(106%);" />
      </div>
    </div>

    <footer class="footer-minimal">
        <div class="footer-left">{t['footer.madeby']}</div>
        <div class="footer-center"><img src="/favicon.svg" style="width: 50px; opacity: 0.5;" /></div>
        <div class="footer-right">Secured by Cloudflare</div>
    </footer>
  </main>

  <style>
    /* Пуста плашка зверху */
    .top-spacer {
        height: 100px;
        width: 100%;
    }

    .waitlist-input {
        padding: 30px; 
        border-radius: 60px; 
        border: 5px solid white; 
        background: transparent; 
        color: white; 
        font-size: clamp(1.2rem, 4vw, 2rem); /* Адаптивний шрифт інпута */
        font-family: 'ActayWide', sans-serif; 
        font-weight: 900;
        width: 100%;
        box-sizing: border-box;
    }

    .waitlist-btn {
        padding: 30px; 
        border-radius: 60px; 
        border: 5px solid black; 
        background: var(--wd-lime); 
        font-size: clamp(1.5rem, 5vw, 2.5rem); 
        font-weight: 900; 
        text-transform: uppercase; 
        cursor: pointer; 
        font-family: 'ActayWide', sans-serif; 
        transition: 0.3s; 
        box-shadow: 8px 8px 0px white;
    }

    .card-brutal {
        border: 8px solid black; border-radius: clamp(40px, 8vw, 80px);
        box-shadow: 25px 25px 0px black; padding: clamp(2.5rem, 8vw, 80px) clamp(1.5rem, 5vw, 50px);
        transition: 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        flex: 1; min-width: 350px;
    }
    .card-brutal:hover { transform: translate(-10px, -10px) rotate(0deg) !important; box-shadow: 35px 35px 0px black; }
    
    #temp { text-decoration: underline; text-decoration-color: var(--wd-lime); text-decoration-thickness: 8px; }
    
    .row-brutal { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 60px; }
    .row-reverse { flex-wrap: wrap-reverse; }
    
    .icon-link img { transition: 0.4s; }
    .icon-link:hover img { transform: scale(1.3) rotate(15deg); opacity: 1 !important; }

    /* Приховування іконок у вертикальному режимі на мобайлі */
    @media (max-width: 768px) and (orientation: portrait) {
        .icon-link {
            display: none;
        }
        .row-brutal {
            justify-content: center;
        }
    }

    .footer-minimal {
        margin-top: 150px; padding: 40px 0; border-top: 8px solid black;
        display: flex; justify-content: space-between; align-items: center;
        font-weight: 900; text-transform: uppercase; font-size: 0.8rem; opacity: 0.6;
    }

    @media (max-width: 768px) {
        main { padding: 40px 15px !important; }
        .card-brutal { min-width: 100%; box-shadow: 15px 15px 0px black; }
        .footer-minimal { flex-direction: column; gap: 20px; text-align: center; }
        .top-spacer { height: 80px; }
    }
  </style>

  <script is:inline>
    async function updateWeather() { 
      try { 
        const geo = await fetch('https://ipapi.co/json/').then(r => r.json());
        const city = geo.city || 'Bolzano';
        const locSpan = document.getElementById('loc');
        if (locSpan) locSpan.innerText = city.toUpperCase();

        const res = await fetch(`https://api.open-meteo.com/v1/forecast?latitude=${geo.latitude}&longitude=${geo.longitude}&current_weather=true`);
        const data = await res.json();
        const tempSpan = document.getElementById('temp');
        if (tempSpan) tempSpan.innerText = Math.round(data.current_weather.temperature);
      } catch (e) {
        document.getElementById('loc').innerText = 'BOLZANO';
        fetch(`https://api.open-meteo.com/v1/forecast?latitude=46.4983&longitude=11.3548&current_weather=true`)
          .then(r => r.json()).then(data => {
            document.getElementById('temp').innerText = Math.round(data.current_weather.temperature);
          });
      }
    }
    updateWeather();
    
    const form = document.getElementById('waitlist-form');
    const msg = document.getElementById('form-msg');
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const res = await fetch('/api/subscribe', { method: 'POST', body: new FormData(form) });
      const result = await res.json();
      msg.style.display = 'block';
      if (res.ok) {
        msg.innerText = msg.dataset.success; msg.style.background = '#D0FF00'; msg.style.color = 'black'; form.reset();
      } else {
        const isExists = result.error?.includes('already');
        msg.innerText = isExists ? msg.dataset.exists : msg.dataset.error;
        msg.style.background = 'red'; msg.style.color = 'white';
      }
    });
  </script>
</Layout>