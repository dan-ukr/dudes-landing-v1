---
export const prerender = true;
import Layout from '../../layouts/layout.astro';
import { ui } from '../../i18n/ui';

export function getStaticPaths() {
  return [
    {params: {lang: 'en'}}, {params: {lang: 'ua'}}, {params: {lang: 'it'}},
    {params: {lang: 'de'}}, {params: {lang: 'es'}}, {params: {lang: 'pt'}},
    {params: {lang: 'fr'}}, {params: {lang: 'be'}}, {params: {lang: 'pl'}}
  ];
}

const { lang } = Astro.params;
const t = ui[lang as keyof typeof ui];
---

<Layout lang={lang}>
  <main style="max-width: 1200px; margin: 0 auto; padding: 120px 20px; text-align: center;">
    
    <div style="margin-bottom: 80px;">
      <h1 style="font-size: clamp(4rem, 12vw, 10rem); font-weight: 900; text-transform: uppercase; font-style: italic; line-height: 0.8; margin-bottom: 40px; letter-spacing: -0.05em;">
        {t['hero.title']}
      </h1>
      <p style="font-size: 2rem; font-weight: 900; text-transform: uppercase; opacity: 0.8;">
         IT'S <span id="temp" style="text-decoration: underline; text-decoration-color: var(--wd-lime); text-decoration-thickness: 8px;">--</span>°C IN BOLZANO.
      </p>
    </div>

    <section id="waitlist-form" style="background: black; padding: 80px 40px; border-radius: 80px; border: 8px solid black; box-shadow: 25px 25px 0px var(--wd-yellow); margin-bottom: 150px; transform: rotate(-1deg);">
      <h2 style="color: white; font-size: clamp(2rem, 5vw, 4rem); text-transform: uppercase; font-style: italic; margin-bottom: 50px; line-height: 1;">
        {t['waitlist.title']}
      </h2>
      <form style="display: flex; flex-direction: column; gap: 25px; max-width: 800px; margin: 0 auto;">
        <input type="email" name="email" placeholder={t['waitlist.placeholder']} style="padding: 30px; border-radius: 60px; border: 5px solid white; background: transparent; color: white; font-size: 2rem; font-family: 'ActayWide'; font-weight: 900;" required />
        <button type="submit" style="padding: 30px; border-radius: 60px; border: 5px solid black; background: var(--wd-lime); font-size: 2.5rem; font-weight: 900; text-transform: uppercase; cursor: pointer; font-family: 'ActayWide'; transition: 0.3s; box-shadow: 8px 8px 0px white;">
          {t['waitlist.btn']}
        </button>
      </form>
      <div id="form-msg" style="display: none; margin-top: 40px; font-size: 2rem; font-weight: 900; text-transform: uppercase; font-style: italic; padding: 30px; border-radius: 30px;"></div>
    </section>

    <div style="display: flex; flex-direction: column; gap: 120px; text-align: left;">
      
      <div style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 60px;">
        <div class="card-brutal" style="background: var(--wd-lime); flex: 1; min-width: 350px; transform: rotate(2deg);">
          <h3 style="font-size: 4rem; text-transform: uppercase; font-style: italic; line-height: 0.9; margin: 0;">{t['feature.bias.title']}</h3>
          <p style="font-size: 1.5rem; font-weight: 900; margin-top: 30px; line-height: 1.1;">{t['feature.bias.desc']}</p>
        </div>
        <a href="#temp" style="transition: 0.4s;"><img src="/icons/sun.svg" style="width: 250px; opacity: 0.3;" onmouseover="this.style.transform='scale(1.3) rotate(15deg)'; this.style.opacity='1'" onmouseout="this.style.transform='scale(1) rotate(0deg)'; this.style.opacity='0.3'" /></a>
      </div>

      <div style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap-reverse; gap: 60px;">
        <a href="#waitlist-form" style="transition: 0.4s;"><img src="/icons/shirt.svg" style="width: 250px; opacity: 0.3;" onmouseover="this.style.transform='scale(1.3) rotate(-15deg)'; this.style.opacity='1'" onmouseout="this.style.transform='scale(1) rotate(0deg)'; this.style.opacity='0.3'" /></a>
        <div class="card-brutal" style="background: var(--wd-pink); flex: 1; min-width: 350px; transform: rotate(-2deg);">
          <h3 style="font-size: 4rem; text-transform: uppercase; font-style: italic; line-height: 0.9; margin: 0;">{t['feature.outfits.title']}</h3>
          <p style="font-size: 1.5rem; font-weight: 900; margin-top: 30px; line-height: 1.1;">{t['feature.outfits.desc']}</p>
        </div>
      </div>

      <div class="card-brutal" style="background: black; color: var(--wd-lime); border-color: var(--wd-lime); max-width: 900px; margin: 60px auto; text-align: center; transform: rotate(1deg);">
          <h3 style="font-size: 5rem; text-transform: uppercase; font-style: italic; line-height: 0.8; margin-bottom: 30px;">MORE FIRE COMING</h3>
          <p style="font-size: 1.8rem; font-weight: 900; line-height: 1.2;">Wardrobe sync, AI style tips, and zero 'what should I wear' stress. Stay tuned.</p>
          <img src="/icons/glasses.svg" style="width: 180px; margin-top: 50px; filter: invert(81%) sepia(87%) saturate(2976%) hue-rotate(24deg) brightness(108%) contrast(106%);" />
      </div>
    </div>

    <footer style="margin-top: 200px; font-size: clamp(4rem, 15vw, 15rem); font-weight: 900; text-transform: uppercase; font-style: italic; opacity: 0.03; line-height: 0.7; letter-spacing: -0.08em;">
        DUDES INC 2026 BOLZANO
    </footer>
  </main>

  <style>
    .card-brutal {
        border: 8px solid black; border-radius: 80px;
        box-shadow: 25px 25px 0px black; padding: 80px 50px;
        transition: 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    .card-brutal:hover { transform: translate(-10px, -10px) rotate(0deg) !important; box-shadow: 35px 35px 0px black; }
  </style>

  <script is:inline>
    async function updateWeather() { try { const res = await fetch(`https://api.open-meteo.com/v1/forecast?latitude=46.4983&longitude=11.3548&current_weather=true`); const data = await res.json(); document.getElementById('temp').innerText = Math.round(data.current_weather.temperature); } catch (e) {} }
    updateWeather();
    
    const form = document.querySelector('form');
    const msg = document.getElementById('form-msg');
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const res = await fetch('/api/subscribe', { method: 'POST', body: new FormData(form) });
      msg.style.display = 'block';
      if (res.ok) {
        msg.innerText = "YO, YOU'RE IN! 🔥"; msg.style.background = '#D0FF00'; msg.style.color = 'black'; form.reset();
      } else {
        msg.innerText = "ALREADY IN THE SQUAD, BRO!"; msg.style.background = 'red'; msg.style.color = 'white';
      }
    });
  </script>
</Layout>