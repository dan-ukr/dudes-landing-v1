---
export const prerender = true;
import Layout from '../../layouts/layout.astro';
import Modal from '../../components/Modal.astro';
import DudesLogo from '../../components/DudesLogo.astro';
import { ui, languages, PRODUCTS, WEATHERDUDE_GOOGLE_PLAY_URL, WEATHERDUDE_STATS } from '../../i18n/ui';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = ui[lang as keyof typeof ui];

const team = [
  { key: 'daniil', name: 'Daniil Mezentsev', initial: 'D', color: 'var(--wd-pink)' },
  { key: 'alexei', name: 'Alexei Karavan', initial: 'A', color: 'var(--md-lime)' },
  { key: 'fiorella', name: 'Fiorella Licciardiello', initial: 'F', color: 'var(--wd-yellow)' },
] as const;

const detailSections = ['inspiration', 'objectives', 'personalization', 'why'] as const;
---

<Layout lang={lang} title="DUDES — Your life, calibrated to you">
  <main>
    <!-- ===================== HERO ===================== -->
    <section id="top" class="band band-navy hero">
      <div class="section-inner">
        <DudesLogo />
        <p class="hero-kicker">{t['hero.kicker']}</p>
      </div>
    </section>

    <!-- ===================== MOTTO ===================== -->
    <section class="band band-light motto">
      <div class="section-inner">
        <h1 class="motto-headline">{t['motto.headline']}</h1>
        <p class="motto-subline">{t['motto.subline']}</p>
      </div>
    </section>

    <!-- ===================== EXPLAINER ===================== -->
    <section class="band band-black explainer">
      <div class="section-inner">
        <h2 class="section-title">{t['explainer.title']}</h2>
        <div class="explainer-grid">
          <div class="explainer-item">
            <h3>{t['explainer.ai.title']}</h3>
            <p>{t['explainer.ai.body']}</p>
          </div>
          <div class="explainer-item">
            <h3>{t['explainer.pricing.title']}</h3>
            <p>{t['explainer.pricing.body']}</p>
          </div>
          <div class="explainer-item">
            <h3>{t['explainer.hiring.title']}</h3>
            <p>{t['explainer.hiring.body']}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== PRODUCTS ===================== -->
    <section id="products" class="band band-navy products">
      <div class="section-inner">
        <h2 class="section-title">{t['products.title']}</h2>
        <p class="section-subtitle">{t['products.subtitle']}</p>

        <div class="product-grid">
          <button class="product-card pc-weatherdude" onclick="document.getElementById('modal-weatherdude').showModal()">
            <span class="status-badge status-live">{t['products.status.live']}</span>
            <span class="product-logo-wrap"><img src={PRODUCTS.weatherdude.logo} alt="" class="product-logo" /></span>
            <span class="product-name">{PRODUCTS.weatherdude.name}</span>
            <span class="product-pitch">{t['products.weatherdude.pitch']}</span>
            <span class="card-cta">{t['products.cta.viewDetails']} →</span>
          </button>

          <button class="product-card pc-mountaindude is-dev" onclick="document.getElementById('modal-mountaindude').showModal()">
            <span class="status-badge status-dev">{t['products.status.dev']}</span>
            <span class="product-logo-wrap"><img src={PRODUCTS.mountaindude.logo} alt="" class="product-logo" /></span>
            <span class="product-name">{PRODUCTS.mountaindude.name}</span>
            <span class="product-pitch">{t['products.mountaindude.pitch']}</span>
            <span class="card-cta">{t['products.cta.viewDetails']} →</span>
          </button>

          <button class="product-card pc-hungrydude is-dev" onclick="document.getElementById('modal-hungrydude').showModal()">
            <span class="status-badge status-dev">{t['products.status.dev']}</span>
            <span class="product-logo-wrap"><img src={PRODUCTS.hungrydude.logo} alt="" class="product-logo" /></span>
            <span class="product-name">{PRODUCTS.hungrydude.name}</span>
            <span class="product-pitch">{t['products.hungrydude.pitch']}</span>
            <span class="card-cta">{t['products.cta.viewDetails']} →</span>
          </button>
        </div>
      </div>
    </section>

    <!-- ===================== TEAM ===================== -->
    <section id="team" class="band band-light team">
      <div class="section-inner">
        <h2 class="section-title">{t['team.title']}</h2>
        <p class="section-subtitle">{t['team.subtitle']}</p>

        <div class="team-grid">
          {team.map((member) => (
            <div class="team-card">
              <!-- TODO: swap for a real headshot <img> once files are provided -->
              <div class="avatar-placeholder" style={`background:${member.color}`}>{member.initial}</div>
              <h3>{member.name}</h3>
              <p class="team-role">{t[`team.${member.key}.role` as keyof typeof t]}</p>
              <p class="team-bio">{t[`team.${member.key}.bio` as keyof typeof t]}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===================== CONTACT ===================== -->
    <section id="contact" class="band band-black contact">
      <div class="section-inner">
        <h2 class="section-title">{t['contact.title']}</h2>
        <p class="section-subtitle">{t['contact.subtitle']}</p>

        <a href="mailto:dudes.info.temp@gmail.com" class="contact-email-btn">{t['contact.emailBtn']}</a>

        <div class="founders">
          <p class="founders-title">{t['contact.founders.title']}</p>
          <div class="founders-row">
            {team.map((member) => (
              <div class="founder-chip">
                <div class="avatar-placeholder small" style={`background:${member.color}`}>{member.initial}</div>
                <div>
                  <p class="founder-name">{member.name}</p>
                  <p class="founder-role">{t[`team.${member.key}.role` as keyof typeof t]}</p>
                </div>
                <!-- TODO: add individual email + LinkedIn link per founder once provided -->
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  </main>

  <!-- ===================== PRODUCT DETAIL OVERLAYS ===================== -->
  <Modal id="modal-weatherdude" title={PRODUCTS.weatherdude.name} fullscreen accent="var(--wd-white)">
    <div class="product-detail pd-weatherdude">
      <span class="detail-logo-wrap"><img src={PRODUCTS.weatherdude.logo} alt="" class="detail-logo" /></span>
      <p class="detail-tagline">{t['products.weatherdude.detail.headline']}</p>

      {detailSections.map((section) => (
        <div class="detail-section">
          <h4>{t[`detail.section.${section}` as keyof typeof t]}</h4>
          <p>{t[`products.weatherdude.detail.${section}` as keyof typeof t]}</p>
        </div>
      ))}

      <div class="detail-section stats-section">
        <h4>{t['detail.section.stats']}</h4>
        <div class="stats-grid">
          <div class="stat"><span class="stat-label">{t['stats.launched']}</span><span class="stat-value">{WEATHERDUDE_STATS.launched}</span></div>
          <div class="stat"><span class="stat-label">{t['stats.users']}</span><span class="stat-value">{WEATHERDUDE_STATS.users}</span></div>
          <div class="stat"><span class="stat-label">{t['stats.revenue']}</span><span class="stat-value">{t['stats.tba']}</span></div>
        </div>
      </div>

      <div class="store-buttons">
        <a href={WEATHERDUDE_GOOGLE_PLAY_URL} target="_blank" rel="noopener noreferrer" class="store-btn">{t['products.weatherdude.store.googleplay']}</a>
        <span class="store-btn store-btn-disabled" aria-disabled="true" title="iOS app still in development">{t['products.weatherdude.store.iosSoon']}</span>
      </div>

      <div class="capture-block">
        <h4>{t['products.weatherdude.waitlist.title']}</h4>
        <form class="capture-form">
          <input type="email" name="email" placeholder={t['products.weatherdude.waitlist.placeholder']} class="capture-input" required />
          <input type="hidden" name="lang" value={lang} />
          <input type="hidden" name="product" value="weatherdude" />
          <button type="submit" class="capture-btn wd-btn">{t['products.weatherdude.waitlist.btn']}</button>
        </form>
        <div class="form-msg" data-success={t['form.success']} data-error={t['form.error']} data-exists={t['form.exists']}></div>
      </div>
    </div>
  </Modal>

  <Modal id="modal-mountaindude" title={PRODUCTS.mountaindude.name} fullscreen accent="var(--md-gray)" accentText="var(--md-white)">
    <div class="product-detail pd-mountaindude">
      <span class="detail-logo-wrap"><img src={PRODUCTS.mountaindude.logo} alt="" class="detail-logo" /></span>
      <p class="detail-tagline">{t['products.mountaindude.detail.headline']}</p>

      {detailSections.map((section) => (
        <div class="detail-section">
          <h4>{t[`detail.section.${section}` as keyof typeof t]}</h4>
          <p>{t[`products.mountaindude.detail.${section}` as keyof typeof t]}</p>
        </div>
      ))}

      <div class="detail-section stats-section">
        <h4>{t['detail.section.stats']}</h4>
        <p class="stats-soon">{t['detail.section.comingSoon']}</p>
      </div>

      <div class="capture-block">
        <h4>{t['products.mountaindude.notify.title']}</h4>
        <form class="capture-form">
          <input type="email" name="email" placeholder={t['products.mountaindude.notify.placeholder']} class="capture-input" required />
          <input type="hidden" name="lang" value={lang} />
          <input type="hidden" name="product" value="mountaindude" />
          <button type="submit" class="capture-btn md-btn">{t['products.mountaindude.notify.btn']}</button>
        </form>
        <div class="form-msg" data-success={t['form.success']} data-error={t['form.error']} data-exists={t['form.exists']}></div>
      </div>
    </div>
  </Modal>

  <Modal id="modal-hungrydude" title={PRODUCTS.hungrydude.name} fullscreen accent="var(--hd-cream)">
    <div class="product-detail pd-hungrydude">
      <span class="detail-logo-wrap"><img src={PRODUCTS.hungrydude.logo} alt="" class="detail-logo" /></span>
      <p class="detail-tagline">{t['products.hungrydude.detail.headline']}</p>

      {detailSections.map((section) => (
        <div class="detail-section">
          <h4>{t[`detail.section.${section}` as keyof typeof t]}</h4>
          <p>{t[`products.hungrydude.detail.${section}` as keyof typeof t]}</p>
        </div>
      ))}

      <div class="detail-section stats-section">
        <h4>{t['detail.section.stats']}</h4>
        <p class="stats-soon">{t['detail.section.comingSoon']}</p>
      </div>

      <div class="capture-block">
        <h4>{t['products.hungrydude.notify.title']}</h4>
        <form class="capture-form">
          <input type="email" name="email" placeholder={t['products.hungrydude.notify.placeholder']} class="capture-input" required />
          <input type="hidden" name="lang" value={lang} />
          <input type="hidden" name="product" value="hungrydude" />
          <button type="submit" class="capture-btn hd-btn">{t['products.hungrydude.notify.btn']}</button>
        </form>
        <div class="form-msg" data-success={t['form.success']} data-error={t['form.error']} data-exists={t['form.exists']}></div>
      </div>
    </div>
  </Modal>

  <style>
    main { width: 100%; }
    .band { width: 100%; }
    .band-navy { background: var(--dd-navy); color: white; }
    .band-black { background: black; color: white; }
    .band-light { background: var(--wd-white); color: black; }

    .section-inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: 90px 20px;
    }

    .section-title {
      font-size: clamp(2rem, 6vw, 3.5rem);
      text-transform: uppercase;
      font-style: italic;
      font-weight: 900;
      line-height: 0.95;
      text-align: center;
      margin: 0 0 10px;
    }
    .section-subtitle {
      text-align: center;
      font-weight: 700;
      opacity: 0.75;
      max-width: 600px;
      margin: 0 auto 60px;
      font-size: clamp(1rem, 2.5vw, 1.3rem);
    }

    /* ---------- Hero ---------- */
    .hero .section-inner {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 24px;
      padding-top: clamp(90px, 16vw, 140px);
      padding-bottom: 70px;
      text-align: center;
    }
    .hero-kicker {
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-size: clamp(0.9rem, 2.5vw, 1.3rem);
      opacity: 0.75;
    }

    /* ---------- Motto ---------- */
    .motto .section-inner { text-align: center; }
    .motto-headline {
      font-size: clamp(2.2rem, 7vw, 5rem);
      font-weight: 900;
      font-style: italic;
      text-transform: uppercase;
      line-height: 0.95;
      letter-spacing: -0.02em;
      margin: 0 0 24px;
    }
    .motto-subline {
      max-width: 700px;
      margin: 0 auto;
      font-size: clamp(1.1rem, 2.8vw, 1.5rem);
      font-weight: 700;
      opacity: 0.85;
    }

    /* ---------- Explainer ---------- */
    .explainer .section-title { color: var(--wd-lime); }
    .explainer-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 40px;
      margin-top: 50px;
    }
    .explainer-item h3 {
      font-size: clamp(1.5rem, 3.5vw, 2rem);
      font-weight: 900;
      font-style: italic;
      color: var(--wd-lime);
      margin: 0 0 16px;
    }
    .explainer-item p {
      font-size: clamp(1.05rem, 2.2vw, 1.25rem);
      line-height: 1.5;
      font-weight: 500;
      opacity: 0.9;
    }

    /* ---------- Products ---------- */
    .product-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 30px;
    }
    .product-card {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
      text-align: left;
      border: 6px solid black;
      border-radius: 40px;
      padding: 2rem;
      cursor: pointer;
      box-shadow: 14px 14px 0px black;
      transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.3s;
      background: var(--wd-white);
    }
    .product-card:hover {
      transform: translate(-6px, -6px);
      box-shadow: 20px 20px 0px black;
    }
    .pc-weatherdude { background: var(--wd-pink); }
    .pc-mountaindude { background: var(--md-gray); color: var(--md-white); }
    .pc-hungrydude { background: var(--hd-cream); }
    .product-card.is-dev { opacity: 0.9; }

    .product-logo-wrap {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: white;
      border-radius: 18px;
      padding: 10px;
    }
    .product-logo {
      height: 44px;
      width: auto;
      max-width: 90px;
      object-fit: contain;
      display: block;
    }

    .status-badge {
      font-size: 0.75rem;
      font-weight: 900;
      text-transform: uppercase;
      padding: 6px 14px;
      border-radius: 99px;
      border: 3px solid currentColor;
    }
    .status-live { background: var(--wd-lime); color: black; border-color: black; }
    .status-dev { background: transparent; }

    .product-name {
      font-size: clamp(1.6rem, 4vw, 2.2rem);
      font-weight: 900;
    }
    .product-pitch { font-weight: 700; line-height: 1.3; opacity: 0.9; }
    .card-cta { font-weight: 900; text-transform: uppercase; font-size: 0.85rem; margin-top: auto; }

    /* ---------- Product detail overlays ---------- */
    .detail-logo-wrap {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: white;
      border-radius: 22px;
      padding: 14px;
      margin-bottom: 24px;
    }
    .detail-logo {
      height: 60px;
      width: auto;
      max-width: 130px;
      object-fit: contain;
      display: block;
    }
    .detail-tagline {
      font-size: clamp(1.4rem, 3.5vw, 2.1rem);
      font-weight: 900;
      font-style: italic;
      line-height: 1.15;
      margin: 0 0 40px;
    }
    .detail-section { margin-bottom: 32px; }
    .detail-section h4 {
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      font-size: 0.85rem;
      opacity: 0.6;
      margin: 0 0 8px;
    }
    .detail-section p { font-size: 1.1rem; line-height: 1.5; font-weight: 500; margin: 0; }
    .pd-mountaindude { color: var(--md-white); }
    .pd-hungrydude { color: var(--hd-brown); }

    .stats-grid { display: flex; gap: 24px; flex-wrap: wrap; }
    .stat { display: flex; flex-direction: column; gap: 4px; }
    .stat-label { font-size: 0.8rem; font-weight: 900; text-transform: uppercase; opacity: 0.6; }
    .stat-value { font-size: 1.4rem; font-weight: 900; }
    .stats-soon { font-style: italic; opacity: 0.7; }

    .store-buttons { display: flex; gap: 16px; flex-wrap: wrap; margin: 8px 0 32px; }
    .store-btn {
      display: inline-block;
      padding: 14px 24px;
      border-radius: 99px;
      border: 4px solid currentColor;
      font-weight: 900;
      text-decoration: none;
      color: inherit;
      font-size: 0.9rem;
    }
    .store-btn-disabled {
      opacity: 0.5;
      cursor: not-allowed;
      border-style: dashed;
    }

    .capture-block { margin-top: 30px; }
    .capture-block h4 { font-weight: 900; text-transform: uppercase; font-size: 1.1rem; }
    .capture-form { display: flex; gap: 14px; flex-wrap: wrap; }
    .capture-input {
      flex: 1;
      min-width: 220px;
      padding: 16px 20px;
      border-radius: 40px;
      border: 4px solid currentColor;
      background: transparent;
      color: inherit;
      font-weight: 900;
      font-size: 1rem;
    }
    .capture-btn {
      padding: 16px 28px;
      border-radius: 40px;
      border: 4px solid black;
      font-weight: 900;
      text-transform: uppercase;
      cursor: pointer;
      color: black;
    }
    .wd-btn { background: var(--wd-lime); }
    .md-btn { background: var(--md-lime); }
    .hd-btn { background: var(--hd-amber); }

    .form-msg {
      display: none;
      margin-top: 16px;
      font-weight: 900;
      text-transform: uppercase;
      padding: 14px 20px;
      border-radius: 20px;
    }
    .form-msg.ok { background: var(--wd-lime); color: black; }
    .form-msg.err { background: #e5484d; color: white; }

    /* ---------- Team ---------- */
    .team-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 30px;
    }
    .team-card {
      border: 6px solid black;
      border-radius: 40px;
      padding: 2rem;
      background: white;
      box-shadow: 12px 12px 0px black;
      text-align: center;
    }
    .avatar-placeholder {
      width: 90px;
      height: 90px;
      border-radius: 50%;
      border: 5px solid black;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2rem;
      font-weight: 900;
      margin: 0 auto 16px;
      color: black;
    }
    .avatar-placeholder.small { width: 46px; height: 46px; font-size: 1.1rem; margin: 0; }
    .team-card h3 { font-size: 1.3rem; font-weight: 900; margin: 0 0 4px; }
    .team-role { font-weight: 900; text-transform: uppercase; font-size: 0.85rem; opacity: 0.6; margin: 0 0 14px; }
    .team-bio { font-size: 0.95rem; line-height: 1.4; }

    /* ---------- Contact ---------- */
    .contact .section-inner { text-align: center; }
    .contact-email-btn {
      display: inline-block;
      background: white;
      color: black;
      padding: 22px 50px;
      border-radius: 99px;
      font-weight: 900;
      text-transform: uppercase;
      text-decoration: none;
      font-size: clamp(1.1rem, 3vw, 1.5rem);
      box-shadow: 10px 10px 0px var(--wd-lime);
      border: 5px solid white;
    }
    .founders { margin-top: 70px; }
    .founders-title { font-weight: 900; text-transform: uppercase; opacity: 0.6; margin-bottom: 20px; }
    .founders-row {
      display: flex;
      justify-content: center;
      gap: 24px;
      flex-wrap: wrap;
    }
    .founder-chip {
      display: flex;
      align-items: center;
      gap: 12px;
      background: white;
      color: black;
      border: 4px solid white;
      border-radius: 99px;
      padding: 10px 20px 10px 10px;
      text-align: left;
      box-shadow: 6px 6px 0px var(--wd-lime);
    }
    .founder-name { font-weight: 900; margin: 0; font-size: 0.95rem; }
    .founder-role { font-size: 0.75rem; opacity: 0.6; margin: 0; }

    @media (max-width: 900px) {
      .product-grid, .team-grid, .explainer-grid { grid-template-columns: 1fr; }
    }
    @media (max-width: 768px) {
      .section-inner { padding: 60px 15px; }
    }
  </style>

  <script is:inline>
    document.querySelectorAll('.capture-form').forEach((form) => {
      if (!(form instanceof HTMLFormElement)) return;
      const msg = form.parentElement ? form.parentElement.querySelector('.form-msg') : null;
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const res = await fetch('/api/subscribe', { method: 'POST', body: new FormData(form) });
        const result = await res.json();
        if (!(msg instanceof HTMLElement)) return;
        msg.style.display = 'block';
        if (res.ok) {
          msg.innerText = msg.dataset.success || '';
          msg.classList.add('ok'); msg.classList.remove('err');
          form.reset();
        } else {
          const isExists = result && result.error && result.error.includes('already');
          msg.innerText = isExists ? (msg.dataset.exists || '') : (msg.dataset.error || '');
          msg.classList.add('err'); msg.classList.remove('ok');
        }
      });
    });
  </script>
</Layout>
